# Where the Inbox Copilot FastAPI backend is running. Used only by the Vite dev
# server to proxy API routes, so the browser can call relative paths and no CORS
# policy is needed on the backend during development.
#
# In production, serve this app and the API from the same origin behind one
# reverse proxy, or configure a CORS policy on the backend.
VITE_BACKEND_ORIGIN=http://localhost:8000

# Nothing secret belongs in this file. VITE_* values are compiled into the
# browser bundle and are public: no OAuth client secret, provider API key,
# database URL, or LLM key.
