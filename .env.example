EMAIL_RAG_DATASET_MANIFEST_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/raw/dataset_manifest.json
EMAIL_RAG_RESOLVED_MANIFEST_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/resolved_dataset_manifest.json
EMAIL_RAG_CHUNK_STORE_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/chunks.jsonl
EMAIL_RAG_STATS_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/ingest_stats.json

EMAIL_RAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMAIL_RAG_RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
EMAIL_RAG_REWRITE_MODEL_NAME=t5-small
EMAIL_RAG_ENABLE_CLOUD_REWRITE=false
EMAIL_RAG_CLOUD_REWRITE_PROVIDER=gemini
EMAIL_RAG_CLOUD_REWRITE_MODEL=gemini-2.5-flash

EMAIL_RAG_API_HOST=0.0.0.0
EMAIL_RAG_API_PORT=8000
EMAIL_RAG_UI_HOST=0.0.0.0
EMAIL_RAG_UI_PORT=7860
EMAIL_RAG_API_BASE_URL=http://localhost:8000

# Optional for faster Hugging Face downloads.
HF_TOKEN=

# Optional Gemini cloud rewrite key. Only used when EMAIL_RAG_ENABLE_CLOUD_REWRITE=true.
GEMINI_API_KEY=

# Stage-2 ParadeDB/Postgres backend. RAG_BACKEND=memory (default) needs none
# of this and requires no database. Only set RAG_BACKEND=paradedb once the
# `db` service from docker-compose.yml is up and migrations have been applied
# via `python -m email_thread_rag.scripts.apply_paradedb_migrations`.
RAG_BACKEND=memory
# Matches docker-compose.yml's `db` service (local dev credentials only).
DATABASE_URL=postgresql://email_rag:email_rag_local_dev@localhost:5433/email_rag
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
# Must match the vector(...) column width in
# email_thread_rag/rag/paradedb/migrations/0001_init.sql. Changing this
# requires a new migration + re-embedding backfill, not just this value.
EMBEDDING_DIM=384
HYBRID_LEXICAL_WEIGHT=1.0
HYBRID_DENSE_WEIGHT=1.0
HYBRID_RRF_K=60
HYBRID_CANDIDATE_LIMIT=40
