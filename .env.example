EMAIL_RAG_DATASET_MANIFEST_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/raw/dataset_manifest.json
EMAIL_RAG_RESOLVED_MANIFEST_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/resolved_dataset_manifest.json
EMAIL_RAG_CHUNK_STORE_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/chunks.jsonl
EMAIL_RAG_STATS_PATH=/Users/aditya/Downloads/speaker_state_resolver 2/Nexus Ocean/email_thread_rag/data/processed/ingest_stats.json

EMAIL_RAG_EMBEDDING_MODEL_NAME=Alibaba-NLP/gte-modernbert-base
EMAIL_RAG_RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
EMAIL_RAG_ENABLE_CLOUD_REWRITE=false
EMAIL_RAG_CLOUD_REWRITE_PROVIDER=gemini
EMAIL_RAG_CLOUD_REWRITE_MODEL=gemini-2.5-flash

EMAIL_RAG_API_HOST=0.0.0.0
EMAIL_RAG_API_PORT=8000
EMAIL_RAG_UI_HOST=0.0.0.0
EMAIL_RAG_UI_PORT=7860
EMAIL_RAG_API_BASE_URL=http://localhost:8000

# Optional for faster Hugging Face downloads.
HF_TOKEN=

# Optional Gemini cloud rewrite key. Only used when EMAIL_RAG_ENABLE_CLOUD_REWRITE=true.
GEMINI_API_KEY=

# Stage-2 ParadeDB/Postgres backend. RAG_BACKEND=memory (default) needs none
# of this and requires no database. Only set RAG_BACKEND=paradedb once the
# `db` service from infra/docker-compose.yml is up and migrations have been applied
# via `python -m email_thread_rag.scripts.apply_paradedb_migrations`.
RAG_BACKEND=memory
# Matches infra/docker-compose.yml's `db` service (local dev credentials only).
DATABASE_URL=postgresql://email_rag:email_rag_local_dev@localhost:5433/email_rag
EMBEDDING_MODEL_ID=Alibaba-NLP/gte-modernbert-base
# Must match the vector(...) column width, currently set by
# email_thread_rag/rag/paradedb/migrations/0006_embedding_dim_768.sql.
# Changing this requires a new migration + re-embedding backfill, not just
# this value. Changing EMBEDDING_MODEL_ID above at the same width also needs a
# full re-embed -- see 0007_reembed_gte_modernbert.sql.
EMBEDDING_DIM=768
HYBRID_LEXICAL_WEIGHT=1.0
HYBRID_DENSE_WEIGHT=1.0
HYBRID_RRF_K=60
HYBRID_CANDIDATE_LIMIT=40

# Stage-3 Gmail sync (optional). RAG_BACKEND=memory needs none of this, and the
# Gmail routes only mount when GMAIL_PUBSUB_SUBSCRIPTION and DATABASE_URL are
# both set. Install with: pip install -e ".[gmail]"
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Must match the OAuth client's authorized redirect URI exactly.
GMAIL_REDIRECT_URI=http://localhost:8000/gmail/oauth/callback
# Where the callback sends the browser after a successful connect.
FRONTEND_BASE_URL=http://localhost:5173
# Topic passed to users.watch; gmail-api-push@system.gserviceaccount.com needs
# the Publisher role on it.
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-sync
# A push naming any other subscription is rejected by the webhook.
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-push
# Expected OIDC audience on the push token (defaults to EMAIL_RAG_API_BASE_URL).
GMAIL_PUBSUB_AUDIENCE=
# Optional: pin the service account email that Pub/Sub pushes as.
GMAIL_PUBSUB_SERVICE_ACCOUNT=
# Base64 32-byte AES-256 key encrypting refresh tokens at rest. Generate with:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# Never commit a real key; use a secret manager outside local dev.
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_TOKEN_KEY_ID=local

# Stage-4 LLM contextualization (optional, OFF by default). When false, nothing
# here is read, no LLM package is imported, ingestion queues no work, and
# retrieval behaves exactly as it did in Stage 2.5.
# Requires RAG_BACKEND=paradedb: contextualization rewrites persisted chunks.
CONTEXT_ENABLED=false
# Any OpenAI-compatible /chat/completions endpoint (vLLM, llama.cpp, Ollama's
# compat layer, a hosted API). Nothing is hard-coded to a specific model and no
# model is ever downloaded.
CONTEXT_BASE_URL=http://164.52.192.196:8002/v1
CONTEXT_MODEL=Medha
# Secret. Read from the environment only -- never commit a real key; use a
# secret manager outside local dev. MEDHA_* are accepted as aliases for the
# three settings above.
CONTEXT_API_KEY=
CONTEXT_TIMEOUT_SECONDS=30
# Budget for the model reply: the 80-token prefix plus its JSON wrapper.
CONTEXT_MAX_TOKENS=96
# Part of each job's input fingerprint. Bumping it re-contextualizes every
# chunk, so leave it unset unless you intend exactly that.
CONTEXT_PROMPT_VERSION=

# --- Stage 5: evidence-backed graph extraction (optional, disabled by default) ---
# Reuses the same OpenAI-compatible endpoint as Stage 4 (MEDHA_* fallbacks apply).
GRAPH_EXTRACTION_ENABLED=false
GRAPH_BASE_URL=
GRAPH_MODEL=
GRAPH_API_KEY=
GRAPH_TIMEOUT_SECONDS=60
GRAPH_MAX_TOKENS=800
GRAPH_PROMPT_VERSION=
GRAPH_SCHEMA_VERSION=

# --- Stage 6: deterministic query planner + graph-evidence retrieval ---
# Enabled by default but inert without graph data (falls back to hybrid).
GRAPH_PLANNER_ENABLED=true
GRAPH_BRANCH_WEIGHT=1.0
GRAPH_CANDIDATE_LIMIT=20
GRAPH_TEMPORAL_CANDIDATE_LIMIT=10

# --- Stage 7: grounded answering + bounded Self-RAG (optional, disabled by default) ---
# Reuses the same OpenAI-compatible endpoint as Stage 4/5 (MEDHA_* fallbacks apply).
# When disabled (default), the deterministic answer path is used and no provider
# or HTTP client is imported. The retry ceiling is fixed at 2 attempts in code.
ANSWER_GENERATION_ENABLED=false
ANSWER_BASE_URL=
ANSWER_MODEL=
ANSWER_API_KEY=
ANSWER_TIMEOUT_SECONDS=60
ANSWER_MAX_TOKENS=800
ANSWER_EVIDENCE_BUDGET=6

# --- Stage 8: PDF attachment extraction + local OCR + page citations ---
# PDF-only. Metadata is persisted and extraction is enqueued during Gmail sync;
# the extraction worker fetches bytes and parses/OCRs off the sync path. OCR is
# optional (install the 'ocr' extra) and off by default: with it disabled or
# unavailable, a scanned page is recorded as unavailable, never invented.
ATTACHMENT_EXTRACTION_ENABLED=true
ATTACHMENT_MAX_BYTES=20000000
ATTACHMENT_OCR_ENABLED=false
